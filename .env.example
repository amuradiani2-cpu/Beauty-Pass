# Beauty Pass - Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret key for token signing (use a long random string)
JWT_SECRET=your-very-long-secret-key-here

# Email configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Server port
PORT=3000

# Base URL for the site
BASE_URL=https://beautypass-website.onrender.com

# TBC Bank payment integration (optional)
TBC_API_URL=https://api.tbcbank.ge/v1/tpay/payment
TBC_OAUTH_URL=https://identity.tbcbank.ge/connect/token
TBC_API_KEY=
TBC_API_SECRET=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Magti SMS (optional, Georgia)
MAGTI_USERNAME=
MAGTI_PASSWORD=
